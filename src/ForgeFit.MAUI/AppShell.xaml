<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="ForgeFit.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ForgeFit.MAUI.Views"
    xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    FlyoutBehavior="Disabled"
    Title="ForgeFit"
    NavBarVisibilityAnimationEnabled="True"
    PresentationMode="NotAnimated"
    TabBarBackgroundColor="{StaticResource Surface}"
    TabBarTitleColor="{StaticResource Primary}"
    TabBarUnselectedColor="{StaticResource TextSecondary}"
    TabBarForegroundColor="{StaticResource Primary}">

    <TabBar>
        <Tab Title="{maui:Translate DiaryPageTitle}"
             Icon="diary.svg">
            <ShellContent
                ContentTemplate="{DataTemplate views:DiaryPageView}"
                Route="DiaryPageView" />
        </Tab>

        <Tab Title="{maui:Translate WorkoutPageTitle}"
             Icon="workout.svg">
            <ShellContent
                ContentTemplate="{DataTemplate views:WorkoutPageView}"
                Route="WorkoutPageView" />
        </Tab>

        <Tab Title="{maui:Translate ProfilePageTitle}"
             Icon="profile.svg">
            <ShellContent
                ContentTemplate="{DataTemplate views:ProfilePageView}"
                Route="ProfilePageView" />
        </Tab>
    </TabBar>

</Shell>
