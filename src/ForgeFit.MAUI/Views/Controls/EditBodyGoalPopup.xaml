<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:sys="using:System"
             x:Class="ForgeFit.MAUI.Views.Controls.EditBodyGoalPopup"
             BackgroundColor="#90000000">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding CloseEditBodyGoalCommand}" />
    </ContentView.GestureRecognizers>

    <Border Style="{StaticResource CardStyle}"
            VerticalOptions="Center"
            HorizontalOptions="Fill"
            Padding="0"
            Margin="20">

        <Border.GestureRecognizers>
            <TapGestureRecognizer />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="12" Padding="20">
            <Label Style="{StaticResource LabelBodyBold}"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   Text="{maui:Translate Profile_BodyGoal}" />
            
            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBodyBold}" 
                       Text="{maui:Translate Goal_Title}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Text="{Binding EditBodyGoalTitle}"
                           MaxLength="20"
                           Placeholder="{maui:Translate Goal_TitlePlaceholder}" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBodyBold}" 
                       Text="{maui:Translate Goal_TargetWeight}" 
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Text="{Binding EditTargetWeight}"
                           Keyboard="Numeric"
                           HorizontalTextAlignment="Center">
                        <Entry.Behaviors>
                            <behaviors:PositiveOnlyBehavior />
                        </Entry.Behaviors>
                    </Entry>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBodyBold}" 
                       Text="{maui:Translate Goal_Description}" 
                       FontSize="12" 
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}" HeightRequest="80">
                    <Editor Text="{Binding EditBodyGoalDescription}"
                            Placeholder="{maui:Translate Goal_DescriptionPlaceholder}"
                            MaxLength="200"
                            AutoSize="TextChanges"/>
                </Border>
            </VerticalStackLayout>
        
            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBodyBold}" 
                       Text="{maui:Translate Goal_DueDate}" 
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <DatePicker Date="{Binding EditBodyGoalDueDate}"
                                Format="dd.MM.yyyy"
                                MinimumDate="{x:Static sys:DateTime.Today}" />
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Text="{maui:Translate Action_Cancel}"
                        Command="{Binding CloseEditBodyGoalCommand}" />
                <Button Grid.Column="1"
                        ImageSource="check.svg"
                        Text="{maui:Translate Action_Save}"
                        Command="{Binding SaveBodyGoalCommand}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
