<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:xaml="clr-namespace:ForgeFit.MAUI.Constants"
             x:Class="ForgeFit.MAUI.Views.Controls.DurationEntryPopup"
             x:Name="ThisPopup"
             BackgroundColor="#90000000"
             InputTransparent="False">
    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding CancelCommand, Source={x:Reference ThisPopup}}" />
    </ContentView.GestureRecognizers>

    <Border Style="{StaticResource CardStyle}"
            VerticalOptions="Center"
            HorizontalOptions="Fill"
            Padding="0"
            Margin="20">

        <Border.GestureRecognizers>
            <TapGestureRecognizer />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="16" Padding="20">
            <Label Style="{StaticResource LabelBody}"
                   Text="{Binding Title, Source={x:Reference ThisPopup}}"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center" />

            <Label Style="{StaticResource LabelBody}"
                   Text="{maui:Translate Placeholder_EnterDurationMinutes}"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center" />

            <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">

                <Border Style="{StaticResource InputWrapper}" MaximumWidthRequest="50">
                    <Entry x:Name="HoursEntry"
                           Placeholder="0"
                           FontSize="Medium"
                           Keyboard="Numeric"
                           MaxLength="{x:Static xaml:AppConstantsXaml.HoursEntryMaxLength}"
                           HorizontalTextAlignment="Center"
                           TextChanged="OnTimePartsChanged">
                        <Entry.Behaviors>
                            <behaviors:NumericClampBehavior MaxValue="{x:Static xaml:AppConstantsXaml.MaxWorkoutDurationHours}" MinValue="0" Decimals="0" />
                        </Entry.Behaviors>
                    </Entry>
                </Border>

                <Label Text=":"
                       FontSize="Large"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />

                <Border Style="{StaticResource InputWrapper}" MaximumWidthRequest="60">
                    <Entry x:Name="MinutesEntry"
                           Placeholder="00"
                           FontSize="Medium"
                           Keyboard="Numeric"
                           MaxLength="{x:Static xaml:AppConstantsXaml.MinutesEntryMaxLength}"
                           HorizontalTextAlignment="Start"
                           TextColor="{StaticResource TextPrimary}"
                           TextChanged="OnTimePartsChanged">
                        <Entry.Behaviors>
                            <behaviors:NumericClampBehavior MaxValue="59" MinValue="0" Decimals="0" />
                        </Entry.Behaviors>
                    </Entry>
                </Border>

            </HorizontalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Text="{maui:Translate Action_Cancel}"
                        Command="{Binding CancelCommand, Source={x:Reference ThisPopup}}" />

                <Button Grid.Column="1"
                        Text="{maui:Translate Action_Save}"
                        Command="{Binding SaveCommand, Source={x:Reference ThisPopup}}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
