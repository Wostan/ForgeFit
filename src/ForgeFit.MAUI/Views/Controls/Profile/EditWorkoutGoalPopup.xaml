<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:behaviors="using:ForgeFit.MAUI.Behaviors"
             x:Class="ForgeFit.MAUI.Views.Controls.Profile.EditWorkoutGoalPopup"
             BackgroundColor="#90000000">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding CloseEditWorkoutCommand}" />
    </ContentView.GestureRecognizers>

    <Border Style="{StaticResource CardStyle}"
            VerticalOptions="Center"
            HorizontalOptions="Fill"
            Padding="0"
            Margin="20">
        <Border.GestureRecognizers>
            <TapGestureRecognizer />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="12" Padding="20">
            <Label Style="{StaticResource LabelBody}"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   Text="{maui:Translate Profile_WorkoutGoal}" />

            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBody}"
                       Text="{maui:Translate Workout_Frequency}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Text="{Binding EditWorkoutsPerWeek}"
                           Keyboard="Numeric"
                           HorizontalTextAlignment="Center">
                        <Entry.Behaviors>
                            <behaviors:PositiveOnlyBehavior />
                        </Entry.Behaviors>
                    </Entry>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBody}"
                       Text="{maui:Translate Workout_Duration}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Text="{Binding EditDurationMinutes}"
                           Keyboard="Numeric" HorizontalTextAlignment="Center">
                        <Entry.Behaviors>
                            <behaviors:PositiveOnlyBehavior />
                        </Entry.Behaviors>
                    </Entry>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Style="{StaticResource LabelBody}"
                       Text="{maui:Translate Workout_Type}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Border Style="{StaticResource InputWrapper}">
                    <Picker ItemsSource="{Binding WorkoutTypes}"
                            SelectedItem="{Binding EditWorkoutType}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            TitleColor="{StaticResource TextSecondary}"
                            HorizontalTextAlignment="Center" />
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Text="{maui:Translate Action_Cancel}"
                        Command="{Binding CloseEditWorkoutCommand}" />
                <Button Grid.Column="1" ImageSource="check.svg" Text="{maui:Translate Action_Save}"
                        Command="{Binding SaveWorkoutCommand}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
