<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="ForgeFit.MAUI.Views.Controls.Profile.ChangePasswordPopup"
             BackgroundColor="#90000000">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding ClosePasswordPopupCommand}" />
    </ContentView.GestureRecognizers>

    <Border Style="{StaticResource CardStyle}"
            VerticalOptions="Center"
            HorizontalOptions="Fill"
            Padding="0"
            Margin="20">
        <Border.GestureRecognizers>
            <TapGestureRecognizer />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="12" Padding="20">
            <Label Style="{StaticResource LabelBodyBold}"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   Text="{maui:Translate Action_ChangePassword}" />

            <VerticalStackLayout>
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Placeholder="{maui:Translate Password_Old}"
                           Text="{Binding OldPasswordInput}"
                           IsPassword="True"
                           FontSize="16" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Border Style="{StaticResource InputWrapper}">
                    <Entry Placeholder="{maui:Translate Password_New}"
                           Text="{Binding NewPasswordInput}"
                           IsPassword="True"
                           FontSize="16" />
                </Border>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                        Text="{maui:Translate Action_Cancel}"
                        Command="{Binding ClosePasswordPopupCommand}" />
                <Button Grid.Column="1" ImageSource="save.svg"
                        Text="{maui:Translate Action_Save}"
                        Command="{Binding SavePasswordCommand}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
