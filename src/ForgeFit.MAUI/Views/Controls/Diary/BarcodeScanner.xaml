<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scanner="clr-namespace:BarcodeScanner.Mobile;assembly=BarcodeScanner.Mobile.Maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:ForgeFit.MAUI.Views.Controls"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:addFood="clr-namespace:ForgeFit.MAUI.ViewModels.Diary.AddFood"
             x:Class="ForgeFit.MAUI.Views.Controls.Diary.BarcodeScanner"
             x:DataType="addFood:AddFoodPageViewModel"
             BackgroundColor="#90000000"
             InputTransparent="False">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding ScannerVM.ToggleScannerCommand}" />
    </ContentView.GestureRecognizers>

    <Border Style="{StaticResource CardStyle}"
            VerticalOptions="Center"
            HorizontalOptions="Fill"
            Padding="0"
            Margin="20,80"
            StrokeThickness="3">

        <Grid>

            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>

            <controls:NavigationHeader Grid.Row="0"
                                       x:Name="ScannerHeader"
                                       Title="{maui:Translate Search_Barcode}"
                                       BackCommand="{Binding ScannerVM.ToggleScannerCommand}"
                                       ZIndex="2">
                <controls:NavigationHeader.Content>
                    <Grid Padding="0,20,0,16" BackgroundColor="Transparent" VerticalOptions="Start">
                        <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
                            <Label Text="{Binding Title, Source={x:Reference ScannerHeader}}"
                                   Style="{StaticResource LabelH1}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Margin="60,0" />
                        </Grid>

                        <Button HorizontalOptions="Start"
                                Style="{StaticResource TextButton}"
                                ImageSource="arrow_back.svg"
                                Command="{Binding BackCommand, Source={x:Reference ScannerHeader}}"
                                Margin="16,0,0,0">
                            <Button.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{StaticResource TextPrimary}" />
                            </Button.Behaviors>
                        </Button>
                    </Grid>
                </controls:NavigationHeader.Content>
            </controls:NavigationHeader>

            <scanner:CameraView x:Name="CameraView"
                                IsVisible="True"
                                TorchOn="{Binding ScannerVM.IsTorchOn}"
                                OnDetected="CameraView_OnDetected" />

            <BoxView x:Name="CameraCurtain"
                     Color="{StaticResource Surface}"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill"
                     ZIndex="1" />

            <Image Source="frame.svg"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   MaximumWidthRequest="200"
                   MaximumHeightRequest="200"
                   Aspect="AspectFit"
                   Opacity="0.75"
                   InputTransparent="True">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="White" />
                </Image.Behaviors>
            </Image>

            <Image Source="barcode.svg"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   MaximumWidthRequest="120"
                   MaximumHeightRequest="120"
                   Aspect="AspectFit"
                   Opacity="0.5"
                   InputTransparent="True">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="White" />
                </Image.Behaviors>
            </Image>

            <Button ZIndex="2"
                    Style="{StaticResource TextButton}"
                    ImageSource="light_off.svg"
                    Margin="8"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Shadow="{StaticResource TextShadow}"
                    Command="{Binding ScannerVM.ToggleTorchCommand}"
                    AutomationProperties.Name="Turn flashlight on">
                <Button.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="White" />
                </Button.Behaviors>
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding ScannerVM.IsTorchOn}"
                                 Value="True">
                        <Setter Property="ImageSource" Value="light_on.svg" />
                        <Setter Property="AutomationProperties.Name" Value="Turn flashlight off" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </Grid>
    </Border>
</ContentView>