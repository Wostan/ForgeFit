<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ForgeFit.MAUI.Views.Controls.NavigationHeader"
             x:Name="ThisControl">
    <ContentView.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="NavigationBarScrim" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#90000000" Offset="0.5" />
                <GradientStop Color="Transparent" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentView.Resources>
    
    <VerticalStackLayout ZIndex="11">
        <Border Background="{StaticResource NavigationBarScrim}"
                VerticalOptions="Start"
                StrokeThickness="0"
                Padding="0,45,0,0">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0"
                        Style="{StaticResource TextButton}"
                        HorizontalOptions="Start"
                        ImageSource="arrow_back.svg"
                        Command="{Binding BackCommand, Source={x:Reference ThisControl}}"
                        Margin="16,0,0,0">
                    <Button.Behaviors>
                        <toolkit:IconTintColorBehavior TintColor="{StaticResource TextPrimary}" />
                    </Button.Behaviors>
                </Button>

                <Label Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Title, Source={x:Reference ThisControl}}"
                       Style="{StaticResource LabelH2}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       InputTransparent="True" />
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentView>
