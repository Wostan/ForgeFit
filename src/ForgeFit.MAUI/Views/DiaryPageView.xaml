<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:diaryPageControlTemplates="clr-namespace:ForgeFit.MAUI.Views.DiaryPageControlTemplates"
             x:Class="ForgeFit.MAUI.Views.DiaryPageView">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContentStackLayout}">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Style="{StaticResource Headline}" Text="Today" VerticalOptions="Center" />
                    <DatePicker Grid.Column="1" VerticalOptions="Center" FontAttributes="Bold" FontSize="16" />
                </Grid>

                <diaryPageControlTemplates:DiarySummaryView />
                <diaryPageControlTemplates:DiaryMealsView />
                <diaryPageControlTemplates:DiaryHydrationView />
                <diaryPageControlTemplates:DiaryWeightView />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>
