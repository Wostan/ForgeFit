<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:progressRing="clr-namespace:MPowerKit.ProgressRing;assembly=MPowerKit.ProgressRing"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:ForgeFit.MAUI.ViewModels"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:DataType="local:DiaryPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Diary.Templates.DiaryMealsView">
    <VerticalStackLayout Spacing="4">

        <Label Style="{StaticResource LabelBodyBold}"
               Text="{maui:Translate Diary_Meals}"
               TextColor="{StaticResource TextSecondary}" />

        <Border Style="{StaticResource CardStyle}"
                Padding="0">
            <VerticalStackLayout Padding="16" Spacing="16">
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                    <progressRing:ProgressRing Color="{StaticResource Primary}"
                                               WidthRequest="30"
                                               HeightRequest="30"
                                               Progress="0.75" />
                    <Label Text="🍳" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{maui:Translate Meal_Breakfast}"
                               Style="{StaticResource LabelBodyBold}"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="431"
                                          Style="{StaticResource LabelBodyBold}"
                                          TextColor="{StaticResource TextPrimary}" />
                                    <Span Text=" / "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="824"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="{maui:Translate Nutrient_Kcal}"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Style="{StaticResource TextButton}"
                            ImageSource="add.svg"
                            Command="{Binding GoToMealDetailsCommand}">
                        <Button.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Button.Behaviors>
                    </Button>

                </Grid>

                <BoxView Color="{StaticResource BorderColor}"
                         HeightRequest="1" />

                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                    <progressRing:ProgressRing Color="{StaticResource Primary}"
                                               WidthRequest="30"
                                               HeightRequest="30"
                                               Progress="0.75" />
                    <Label Text="🍲" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{maui:Translate Meal_Lunch}"
                               Style="{StaticResource LabelBodyBold}"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="431"
                                          Style="{StaticResource LabelBodyBold}"
                                          TextColor="{StaticResource TextPrimary}" />
                                    <Span Text=" / "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="824"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="{maui:Translate Nutrient_Kcal}"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Style="{StaticResource TextButton}"
                            ImageSource="add.svg"
                            Command="{Binding GoToMealDetailsCommand}">
                        <Button.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Button.Behaviors>
                    </Button>

                </Grid>

                <BoxView Color="{StaticResource BorderColor}"
                         HeightRequest="1" />

                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                    <progressRing:ProgressRing Color="{StaticResource Primary}"
                                               WidthRequest="30"
                                               HeightRequest="30"
                                               Progress="0.95" />
                    <Label Text="🍝" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{maui:Translate Meal_Dinner}"
                               Style="{StaticResource LabelBodyBold}"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="431"
                                          Style="{StaticResource LabelBodyBold}"
                                          TextColor="{StaticResource TextPrimary}" />
                                    <Span Text=" / "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="824"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="{maui:Translate Nutrient_Kcal}"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Style="{StaticResource TextButton}"
                            ImageSource="add.svg"
                            Command="{Binding GoToMealDetailsCommand}">
                        <Button.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Button.Behaviors>
                    </Button>

                </Grid>

                <BoxView Color="{StaticResource BorderColor}"
                         HeightRequest="1" />

                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                    <progressRing:ProgressRing Color="{StaticResource Primary}"
                                               WidthRequest="30"
                                               HeightRequest="30"
                                               Progress="0.5" />
                    <Label Text="🍌" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{maui:Translate Meal_Snack}"
                               Style="{StaticResource LabelBodyBold}"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="431"
                                          Style="{StaticResource LabelBodyBold}"
                                          TextColor="{StaticResource TextPrimary}" />
                                    <Span Text=" / "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="824"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                    <Span Text="{maui:Translate Nutrient_Kcal}"
                                          Style="{StaticResource LabelBodyBold}" FontSize="14" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Style="{StaticResource TextButton}"
                            ImageSource="add.svg"
                            Command="{Binding GoToMealDetailsCommand}">
                        <Button.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Button.Behaviors>
                    </Button>

                </Grid>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentView>
