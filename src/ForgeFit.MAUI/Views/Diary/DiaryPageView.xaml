<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ForgeFit.MAUI.ViewModels"
             xmlns:templates="clr-namespace:ForgeFit.MAUI.Views.Diary.Templates"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             behaviors:PageAnimationBehavior.AnimationType="SlideUp"
             x:DataType="local:DiaryPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Diary.DiaryPageView">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContentStackLayout}">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Style="{StaticResource Headline}" Text="Today" VerticalOptions="Center" />
                    <DatePicker Grid.Column="1" VerticalOptions="Center" FontAttributes="Bold" FontSize="16" />
                </Grid>

                <templates:DiarySummaryView />
                <templates:DiaryMealsView />
                <templates:DiaryHydrationView />
                <templates:DiaryWeightView />

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>
