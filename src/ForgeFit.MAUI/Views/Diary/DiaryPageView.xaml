<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ForgeFit.MAUI.ViewModels"
             xmlns:templates="clr-namespace:ForgeFit.MAUI.Views.Diary.Templates"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             xmlns:controls="clr-namespace:ForgeFit.MAUI.Views.Controls"
             behaviors:PageAnimationBehavior.AnimationType="SlideUp"
             x:DataType="local:DiaryPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Diary.DiaryPageView"
             x:Name="ThisPage">
    <ContentPage.Content>
        <Grid>
            <controls:NavigationHeader ZIndex="11" ShowBackButton="False">
                <controls:NavigationHeader.CustomTitleView>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Style="{StaticResource Headline}" 
                               Text="{Binding BindingContext.DateTitle, Source={x:Reference ThisPage}}" 
                               VerticalOptions="Center" />

                        <DatePicker Grid.Column="2" 
                                    Date="{Binding BindingContext.SelectedDate, Source={x:Reference ThisPage}, Mode=TwoWay}"
                                    VerticalOptions="Center" 
                                    FontSize="16" />
                    </Grid>
                </controls:NavigationHeader.CustomTitleView>
            </controls:NavigationHeader>

            <controls:StateContainer IsLoading="{Binding IsLoading}"
                                     IsError="{Binding IsError}"
                                     ErrorMessage="{Binding Error.Localized}"
                                     RetryCommand="{Binding InitializeCommand}">
                <RefreshView IsRefreshing="{Binding IsRefreshing}"
                             Command="{Binding RefreshCommand}">
                    <ScrollView>
                        <VerticalStackLayout Style="{StaticResource MainContentStackLayout}">

                            <templates:DiarySummaryView />
                            <templates:DiaryMealsView />
                            <templates:DiaryHydrationView />
                            <templates:DiaryWeightView />

                        </VerticalStackLayout>
                    </ScrollView>
                </RefreshView>
            </controls:StateContainer>
        </Grid>
    </ContentPage.Content>
</ContentPage>
