<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             xmlns:controls="clr-namespace:ForgeFit.MAUI.Views.Controls"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:diary="using:ForgeFit.MAUI.Views.Controls.Diary"
             xmlns:meals="clr-namespace:ForgeFit.MAUI.ViewModels.Diary.Meals"
             xmlns:templates="clr-namespace:ForgeFit.MAUI.Views.Diary.MealDetailsTemplates"
             behaviors:PageAnimationBehavior.AnimationType="Pop"
             Shell.NavBarIsVisible="False"
             x:DataType="meals:MealDetailsPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Diary.MealDetailsPageView"
             x:Name="ThisPage">
    <ContentPage.Content>
        <Grid>
            <Grid RowDefinitions="Auto, *, Auto">

                <controls:NavigationHeader Grid.Row="0"
                                           Title="{Binding BindingContext.MealTitle, Source={x:Reference ThisPage}}" />

                <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout Padding="20,0,20,20" Spacing="20">
                        <templates:MealMacrosView />
                        <templates:MealFoodListView />
                    </VerticalStackLayout>
                </ScrollView>

                <Button Grid.Row="2"
                        ImageSource="add_big.svg"
                        Text="{maui:Translate Action_AddFood}"
                        Margin="20"
                        VerticalOptions="End"
                        Command="{Binding GoToAddFoodCommand}" />
            </Grid>

            <diary:FoodDetails ZIndex="10" BindingContext="{Binding DetailsVM}">
                <diary:FoodDetails.Behaviors>
                    <behaviors:FadeVisibilityBehavior IsVisible="{Binding IsFoodDetailsVisible}" />
                </diary:FoodDetails.Behaviors>
            </diary:FoodDetails>

            <diary:CreateRecipeView ZIndex="13" BindingContext="{Binding CreateRecipeVM}">
                <diary:CreateRecipeView.Behaviors>
                    <behaviors:FadeVisibilityBehavior IsVisible="{Binding BindingContext.PopupVM.IsCreateRecipePopupVisible, Source={x:Reference ThisPage}}" />
                </diary:CreateRecipeView.Behaviors>
            </diary:CreateRecipeView>
        </Grid>
    </ContentPage.Content>
</ContentPage>