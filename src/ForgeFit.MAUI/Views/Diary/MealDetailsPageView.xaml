<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ForgeFit.MAUI.Behaviors"
             xmlns:controls="clr-namespace:ForgeFit.MAUI.Views.Controls"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:diary="using:ForgeFit.MAUI.Views.Controls.Diary"
             xmlns:meals="clr-namespace:ForgeFit.MAUI.ViewModels.Diary.Meals"
             xmlns:templates="clr-namespace:ForgeFit.MAUI.Views.Diary.MealDetailsTemplates"
             behaviors:PageAnimationBehavior.AnimationType="Pop"
             Shell.NavBarIsVisible="False"
             x:DataType="meals:MealDetailsPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Diary.MealDetailsPageView"
             x:Name="ThisPage">
    <ContentPage.Content>
        <Grid>

            <ScrollView VerticalScrollBarVisibility="Never" ZIndex="0">
                <VerticalStackLayout Style="{StaticResource MainContentStackLayout}" Spacing="20">
                    <templates:MealMacrosView />
                    <templates:MealFoodListView Margin="0,0,0,60" />
                </VerticalStackLayout>
            </ScrollView>

            <controls:NavigationHeader VerticalOptions="Start"
                                       ZIndex="1"
                                       Title="{Binding BindingContext.MealTitle, Source={x:Reference ThisPage}}" />

            <Button ImageSource="add_big.svg"
                    Text="{maui:Translate Action_AddFood}"
                    Margin="12"
                    VerticalOptions="End"
                    ZIndex="1"
                    Command="{Binding GoToAddFoodCommand}" />

            <diary:FoodDetails ZIndex="17" BindingContext="{Binding DetailsVM}">
                <diary:FoodDetails.Behaviors>
                    <behaviors:FadeVisibilityBehavior IsVisible="{Binding IsFoodDetailsVisible}" />
                </diary:FoodDetails.Behaviors>
            </diary:FoodDetails>

            <diary:FoodDetails ZIndex="17" BindingContext="{Binding CreateRecipeVM.IngredientDetailsVM}">
                <diary:FoodDetails.Behaviors>
                    <behaviors:FadeVisibilityBehavior IsVisible="{Binding IsFoodDetailsVisible}" />
                </diary:FoodDetails.Behaviors>
            </diary:FoodDetails>

            <diary:CreateRecipeView ZIndex="13" BindingContext="{Binding CreateRecipeVM}">
                <diary:CreateRecipeView.Behaviors>
                    <behaviors:FadeVisibilityBehavior
                        IsVisible="{Binding BindingContext.PopupVM.IsCreateRecipePopupVisible, Source={x:Reference ThisPage}}" />
                </diary:CreateRecipeView.Behaviors>
            </diary:CreateRecipeView>

            <diary:RecipeIngredientSearchView ZIndex="15" BindingContext="{Binding CreateRecipeVM.IngredientSearchVM}">
                <diary:RecipeIngredientSearchView.Behaviors>
                    <behaviors:FadeVisibilityBehavior
                        IsVisible="{Binding BindingContext.PopupVM.IsRecipeIngredientSearchPopupVisible, Source={x:Reference ThisPage}}" />
                </diary:RecipeIngredientSearchView.Behaviors>
            </diary:RecipeIngredientSearchView>
        </Grid>
    </ContentPage.Content>
</ContentPage>
