<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:maui="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             xmlns:exerciseSearch="clr-namespace:ForgeFit.MAUI.ViewModels.Workout.ExerciseSearch"
             xmlns:templates="clr-namespace:ForgeFit.MAUI.Views.Workout.ExerciseSearchTemplates"
             x:DataType="exerciseSearch:ExerciseSearchPageViewModel"
             x:Class="ForgeFit.MAUI.Views.Workout.ExerciseSearchTemplates.ExerciseSearchResultsView">
    <CollectionView ItemsSource="{Binding SearchVM.SearchResults}"
                    RemainingItemsThreshold="5"
                    RemainingItemsThresholdReachedCommand="{Binding SearchVM.LoadMoreCommand}"
                    Opacity="{Binding SearchVM.IsLoading, Converter={toolkit:InvertedBoolConverter}}">

        <CollectionView.EmptyView>
            <VerticalStackLayout Spacing="10"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Opacity="0.5"
                                 IsVisible="{Binding SearchVM.IsLoading, Converter={toolkit:InvertedBoolConverter}}">
                <Image Source="search.svg"
                       WidthRequest="100"
                       HeightRequest="100">
                    <Image.Behaviors>
                        <toolkit:IconTintColorBehavior TintColor="{StaticResource TextSecondary}" />
                    </Image.Behaviors>
                </Image>
                <Label Style="{StaticResource LabelBody}"
                       Text="{maui:Translate Search_Empty}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </CollectionView.EmptyView>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
        </CollectionView.ItemsLayout>

        <CollectionView.Header>
            <BoxView HeightRequest="100" BackgroundColor="Transparent" />
        </CollectionView.Header>

        <CollectionView.Footer>
            <BoxView HeightRequest="80" BackgroundColor="Transparent" />
        </CollectionView.Footer>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="exerciseSearch:ExerciseSearchItemViewModel">
                <templates:ExerciseSearchItemCardView />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
