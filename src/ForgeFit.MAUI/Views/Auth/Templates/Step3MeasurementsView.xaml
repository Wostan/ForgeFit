<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="using:LocalizationResourceManager.Maui"
             xmlns:views="using:ForgeFit.MAUI.Views.Auth"
             xmlns:registration="clr-namespace:ForgeFit.MAUI.ViewModels.Registration"
             xmlns:constants="clr-namespace:ForgeFit.MAUI.Constants"
             x:Class="ForgeFit.MAUI.Views.Auth.Templates.Step3MeasurementsView">

    <Grid RowDefinitions="Auto, *, Auto"
          Padding="30,50,30,130"
          x:DataType="registration:RegistrationPageViewModel"
          BindingContext="{Binding Source={RelativeSource AncestorType={x:Type views:RegistrationPageView}}, Path=BindingContext}">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="20"
                             Margin="0, 50, 0, 0">
            <Label Text="{maui:Translate Reg_Title_Measurements}"
                   Style="{StaticResource LabelH1}"
                   HorizontalTextAlignment="Center" />

            <Label Text="{maui:Translate Reg_Subtitle_Measurements}"
                   Style="{StaticResource LabelBody}"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="25" VerticalOptions="Center">

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Style="{StaticResource LabelH1}"
                               Text="{maui:Translate Reg_Height}"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding MeasurementsVM.Height, StringFormat='{0:F0}'}"
                                          TextColor="{StaticResource Primary}"
                                          Style="{StaticResource LabelH1}" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelH1}" />
                                    <Span Text="{maui:Translate Height_Cm}"
                                          Style="{StaticResource LabelBody}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <Slider Minimum="{x:Static constants:AppConstantsXaml.MinHeightCm}"
                            Maximum="{x:Static constants:AppConstantsXaml.MaxHeightCm}"
                            Value="{Binding MeasurementsVM.Height}" />

                    <Grid ColumnDefinitions="Auto, * , Auto" Padding="5,0">
                        <Label Grid.Column="0" Style="{StaticResource LabelBody}" Text="{x:Static constants:AppConstantsXaml.MinHeightCmStr}" />
                        <Label Grid.Column="2" Style="{StaticResource LabelBody}" Text="{x:Static constants:AppConstantsXaml.MaxHeightCmStr}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Style="{StaticResource LabelH1}"
                               Text="{maui:Translate Reg_Weight}"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding MeasurementsVM.Weight, StringFormat='{0:F0}'}"
                                          TextColor="{StaticResource Primary}"
                                          Style="{StaticResource LabelH1}" />
                                    <Span Text=" "
                                          Style="{StaticResource LabelH1}" />
                                    <Span Text="{maui:Translate Weight_Kg}"
                                          Style="{StaticResource LabelBody}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <Slider Minimum="{x:Static constants:AppConstantsXaml.MinWeightKg}"
                            Maximum="{x:Static constants:AppConstantsXaml.MaxWeightKg}"
                            Value="{Binding MeasurementsVM.Weight}" />

                    <Grid ColumnDefinitions="Auto, * , Auto" Padding="5,0">
                        <Label Grid.Column="0" Style="{StaticResource LabelBody}" Text="{x:Static constants:AppConstantsXaml.MinWeightKgStr}" />
                        <Label Grid.Column="2" Style="{StaticResource LabelBody}" Text="{x:Static constants:AppConstantsXaml.MaxWeightKgStr}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Stroke="{Binding MeasurementsVM.BmiColor}"
                VerticalOptions="End">

            <Grid ColumnDefinitions="Auto, *">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="0" MaximumWidthRequest="120">
                    <Label Text="{maui:Translate BMI_Title}"
                           Style="{StaticResource LabelBody}"
                           FontSize="Caption"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding MeasurementsVM.BmiValue, StringFormat='{0:F1}'}"
                           FontSize="Header"
                           FontFamily="MontserratSemiBold"
                           TextColor="{Binding MeasurementsVM.BmiColor}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End">
                    <Label Text="{Binding MeasurementsVM.BmiCategoryText.Localized}"
                           Style="{StaticResource LabelH2}"
                           TextColor="{Binding MeasurementsVM.BmiColor}"
                           HorizontalTextAlignment="End" />

                    <Label Text="{Binding MeasurementsVM.BmiDescription.Localized}"
                           Style="{StaticResource LabelBody}"
                           FontSize="Caption"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentView>
