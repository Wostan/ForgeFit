<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="using:LocalizationResourceManager.Maui"
             xmlns:views="using:ForgeFit.MAUI.Views.Auth"
             xmlns:registration="clr-namespace:ForgeFit.MAUI.ViewModels.Registration"
             x:Class="ForgeFit.MAUI.Views.Auth.Templates.Step4GoalView">
    <ContentView.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#FF7B5A</Color>
        </ResourceDictionary>
    </ContentView.Resources>
    <Grid RowDefinitions="Auto, *, Auto"
          x:DataType="registration:RegistrationPageViewModel"
          BindingContext="{Binding Source={RelativeSource AncestorType={x:Type views:RegistrationPageView}}, Path=BindingContext}">
        <Grid.Padding>
            <OnPlatform x:TypeArguments="Thickness">
                <On Platform="iOS" Value="30,70,30,150" />
                <On Platform="Android" Value="30,50,30,130" />
            </OnPlatform>
        </Grid.Padding>

        <VerticalStackLayout Grid.Row="0"
                             Spacing="20"
                             Margin="0, 50, 0, 0">
            <Label Text="{maui:Translate Reg_Title_Goal}"
                   Style="{StaticResource LabelH1}"
                   HorizontalTextAlignment="Center" />

            <Label Text="{maui:Translate Reg_GoalDisclaimer}"
                   Style="{StaticResource LabelBody}"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="25" VerticalOptions="Center">

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Style="{StaticResource LabelH2}"
                               Text="{maui:Translate Goal_TargetWeight}"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding GoalVM.TargetWeight, StringFormat='{0:F0}'}"
                                          TextColor="{StaticResource Primary}"
                                          Style="{StaticResource LabelH1}" />
                                    <Span Text=" " Style="{StaticResource LabelH1}" />
                                    <Span Text="{maui:Translate Weight_Kg}"
                                          Style="{StaticResource LabelBody}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <Slider Minimum="{Binding GoalVM.MinTargetWeight}"
                            Maximum="{Binding GoalVM.MaxTargetWeight}"
                            Value="{Binding GoalVM.TargetWeight}"
                            ThumbColor="{StaticResource Primary}"
                            MinimumTrackColor="{StaticResource Primary}" />

                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="5,0">
                        <Label Grid.Column="0"
                               Text="{Binding GoalVM.MinTargetWeight, StringFormat='{0:F0}'}"
                               Style="{StaticResource LabelBody}" />

                        <Label Grid.Column="2"
                               Text="{Binding GoalVM.MaxTargetWeight, StringFormat='{0:F0}'}"
                               Style="{StaticResource LabelBody}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout>
                <Border Style="{StaticResource CardStyle}"
                        IsEnabled="{Binding GoalVM.IsDeadlineActive}">
                    <Grid RowDefinitions="Auto, *">
                        <Grid ColumnDefinitions="Auto, *" Grid.Row="0" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="{maui:Translate Goal_DueDate}"
                                   Style="{StaticResource LabelH2}" />

                            <Label Grid.Column="1"
                                   Text="{Binding GoalVM.DaysLeftText}"
                                   Style="{StaticResource LabelBody}"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="Caption"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End" />
                        </Grid>

                        <DatePicker Grid.Row="1"
                                    Date="{Binding GoalVM.GoalDueDate}"
                                    MinimumDate="{Binding GoalVM.MinGoalDate}"
                                    Format="dd MMM yyyy"
                                    FontSize="Title"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                    </Grid>
                </Border>

                <HorizontalStackLayout Spacing="5"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start">
                    <CheckBox IsChecked="{Binding GoalVM.IsNoDeadline}"
                              Color="{StaticResource Primary}" />

                    <Label Text="{maui:Translate Goal_NoDeadline}"
                           VerticalOptions="Center"
                           Style="{StaticResource LabelBody}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoalVM.ToggleDeadlineCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Label Text="{Binding GoalVM.ValidationError.Localized}"
                   TextColor="{StaticResource DangerColor}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
