<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="using:LocalizationResourceManager.Maui"
             xmlns:local="using:ForgeFit.MAUI.ViewModels"
             xmlns:views="using:ForgeFit.MAUI.Views.Auth"
             x:Class="ForgeFit.MAUI.Views.Auth.Templates.Step4GoalView">
    <ContentView.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#FF7B5A</Color> 
        </ResourceDictionary>
    </ContentView.Resources>
    <Grid RowDefinitions="Auto, *, Auto"
          Padding="30,50,30,130"
          x:DataType="local:RegistrationPageViewModel"
          BindingContext="{Binding Source={RelativeSource AncestorType={x:Type views:RegistrationPageView}}, Path=BindingContext}">

        <VerticalStackLayout Grid.Row="0" 
                             Spacing="20" 
                             Margin="0, 50, 0, 0">
            <Label Text="{maui:Translate Reg_Title_Goal}" 
                   Style="{StaticResource LabelH1}" 
                   FontSize="32"
                   HorizontalTextAlignment="Center" />
            
            <Label Text="{maui:Translate Reg_GoalDisclaimer}"
                   Style="{StaticResource LabelBodyBold}"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="25" VerticalOptions="Center">

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" 
                               Style="{StaticResource LabelH2}"
                               Text="{maui:Translate Goal_TargetWeight}" 
                               VerticalOptions="Center"/>
                        
                        <Label Grid.Column="1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding TargetWeight, StringFormat='{0:F0}'}"
                                          TextColor="{StaticResource Primary}"
                                          Style="{StaticResource LabelH1}"
                                          FontSize="36"/> 
                                    <Span Text=" " Style="{StaticResource LabelH1}"/>
                                    <Span Text="{maui:Translate Weight_Kg}"
                                          Style="{StaticResource LabelBodyBold}"
                                          FontSize="20"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <Slider Minimum="{Binding MinTargetWeight}" 
                            Maximum="{Binding MaxTargetWeight}" 
                            Value="{Binding TargetWeight}"
                            ThumbColor="{StaticResource Primary}" 
                            MinimumTrackColor="{StaticResource Primary}"/>
                    
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="5,0">
                        <Label Grid.Column="0" 
                               Text="{Binding MinTargetWeight, StringFormat='{0:F0}'}"
                               Style="{StaticResource LabelBodyBold}" />
                        
                        <Label Grid.Column="2" 
                               Text="{Binding MaxTargetWeight, StringFormat='{0:F0}'}"
                               Style="{StaticResource LabelBodyBold}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout>
                <Border Style="{StaticResource CardStyle}"
                        IsEnabled="{Binding IsDeadlineActive}">
                    <Grid RowDefinitions="Auto, *">
                        <Grid ColumnDefinitions="Auto, *" Grid.Row="0" VerticalOptions="Center">
                            <Label Grid.Column="0" 
                                   Text="{maui:Translate Goal_DueDate}" 
                                   Style="{StaticResource LabelH2}" />
                        
                            <Label Grid.Column="1" 
                                   Text="{Binding DaysLeftText}" 
                                   Style="{StaticResource LabelBodyBold}"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="12"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End" />
                        </Grid>

                        <DatePicker Grid.Row="1"
                                    Date="{Binding GoalDueDate}"
                                    MinimumDate="{Binding MinGoalDate}"
                                    Format="dd MMM yyyy"
                                    FontSize="42"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                    </Grid>
                </Border>
                
                <HorizontalStackLayout Spacing="5" 
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start">
                    <CheckBox IsChecked="{Binding IsNoDeadline}" 
                              Color="{StaticResource Primary}"/>
                
                    <Label Text="{maui:Translate Goal_NoDeadline}" 
                           VerticalOptions="Center"
                           Style="{StaticResource LabelBodyBold}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleDeadlineCommand}" /> 
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
            
            <Label Text="{Binding Error.Localized}"
                   Opacity="{Binding IsError}"
                   TextColor="{StaticResource DangerColor}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </Grid>
</ContentView>
