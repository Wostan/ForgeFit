<?xml version="1.0" encoding="UTF-8"?>
<?xaml-comp compile="true" ?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">PaleGoldenrod</Color>
    <Color x:Key="PrimaryDark">#CDC789</Color>

    <Color x:Key="PageBackground">#000000</Color>

    <Color x:Key="Surface">#0E0E0E</Color>
    <Color x:Key="SurfaceLight">#141414</Color>

    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextPrimaryDark">#000000</Color>
    <Color x:Key="TextSecondary">#B0B0B0</Color>
    <Color x:Key="TextDisabled">#606060</Color>
    <Color x:Key="BorderColor">#333333</Color>

    <Color x:Key="DangerColor">#CF6679</Color>
    <Color x:Key="SuccessColor">#00C853</Color>
    
    <Color x:Key="CarbsColor">#69F0AE</Color>
    <Color x:Key="ProteinColor">#FF8A80</Color>
    <Color x:Key="FatColor">#FFE57F</Color>
    
    <Color x:Key="WaterColor">#81D4FA</Color>
    <LinearGradientBrush x:Key="WaterCardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0E0E0E" Offset="0.0" /> 
        <GradientStop Color="#385B7D" Offset="0.8" /> 
    </LinearGradientBrush>
    
</ResourceDictionary>
