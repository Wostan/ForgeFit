        </Compile>
        <Compile Update="Views\Controls\Profile\ChangePasswordPopup.xaml.cs">
            <DependentUpon>ChangePasswordPopup.xaml</DependentUpon>
            <SubType>Code</SubType>
        </Compile>
        <Compile Update="Views\Controls\Profile\EditBodyGoalPopup.xaml.cs">
