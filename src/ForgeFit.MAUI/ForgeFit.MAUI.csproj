            <SubType>Designer</SubType>
        </MauiXaml>
        <MauiXaml Update="Views\Diary\PhotoRecognitionPage.xaml">
            <SubType>Designer</SubType>
        </MauiXaml>
        <MauiXaml Update="Views\Controls\Diary\FoodDetails.xaml">
